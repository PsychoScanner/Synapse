.gitignore

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node modules (if using npm/node tools)
node_modules/
npm-debug.log
yarn-error.log

# Environment files
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
*.bundle.js

# OS files
.DS_Store
.AppleDouble
.LSOverride
*.exe
*.app

# Temporary files
*.tmp
*.temp
.cache/

# Logs
logs/
*.log
